{
  "name": "recipes",
  "version": "1.0.0",
  "description": "Recipe collection and build scripts",
  "private": true,
  "type": "module",
  "scripts": {
    "build:users": "tsx src/build-users.ts",
    "build:recipes": "tsx src/build-recipes.ts",
    "export": "tsx src/export-recipes.ts",
    "build": "pnpm build:users && pnpm build:recipes && pnpm export",
    "validate": "tsx src/validate.ts",
    "clean": "tsx src/clean.ts"
  },
  "dependencies": {
    "recipes-shared": "workspace:*"
  },
  "devDependencies": {
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.1",
    "markdown-it": "^14.2.0",
    "tsx": "^4.20.6",
    "typescript": "^6.0.3"
  }
}
