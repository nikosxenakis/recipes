# MongoDB Atlas connection string (with password).
# Example: mongodb+srv://USER:PASSWORD@cluster0.example.mongodb.net/recipes?retryWrites=true&w=majority&appName=Cluster0
MONGODB_URI=

# Optional: database name override; defaults to "recipes" if the URI has no path.
MONGODB_DB=recipes

# Optional: when set, POST /api/recipes requires header `x-api-key: <value>`.
# Leave unset to allow open writes.
ADMIN_API_KEY=
